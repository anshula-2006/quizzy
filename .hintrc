{
  "extends": [
    "development"
  ],
  "hints": {
    "meta-charset-utf-8": "off",
    "meta-viewport": "off",
    "axe/language": "off",
    "no-inline-styles": "off",
    "axe/forms": [
      "default",
      {
        "label": "off"
      }
    ],
    "axe/text-alternatives": "off",
    "axe/aria": [
      "default",
      {
        "aria-required-children": "off"
      }
    ],
    "axe/parsing": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "border-color: color-mix(in srgb, var(--red) 52%, transparent)"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 18.6",
    "not safari <= 18.6",
    "not and_ff <= 140",
    "not firefox <= 141"
  ]
}